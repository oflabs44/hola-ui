  "homepage": "https://oflabs44.github.io/hola-ui",
  "items": [
    {
      "$schema": "https://ui.shadcn.com/schema/registry-item.json",
      "name": "theme",
      "type": "registry:theme",
      "title": "Hola theme",
      "description": "Hola UI design tokens — neutrals shifted toward brand hue, translucent overlay borders, asymmetric light/dark.",
      "cssVars": {
        "theme": {
          "color-bg": "var(--hola-bg)",
          "color-surface": "var(--hola-surface)",
          "color-surface-elevated": "var(--hola-surface-elevated)",
          "color-fg": "var(--hola-fg)",
          "color-muted": "var(--hola-muted)",
          "color-brand": "var(--hola-brand)",
          "color-brand-fg": "var(--hola-brand-fg)",
          "color-accent": "var(--hola-accent)",
          "color-accent-fg": "var(--hola-accent-fg)",
          "color-danger": "var(--hola-danger)",
          "color-danger-fg": "var(--hola-danger-fg)",
          "font-sans": "var(--font-geist-sans), ui-sans-serif, system-ui, sans-serif",
          "font-mono": "var(--font-geist-mono), ui-monospace, 'SF Mono', Menlo, monospace"
        },
        "light": {
          "hola-bg": "oklch(1 0 0)",
          "hola-surface": "oklch(0.985 0.002 264)",
          "hola-surface-elevated": "oklch(1 0 0)",
          "hola-fg": "oklch(0.18 0.005 264)",
          "hola-muted": "oklch(0.55 0.01 264)",
          "hola-brand": "oklch(0.22 0.008 264)",
          "hola-brand-fg": "oklch(0.98 0.002 264)",
          "hola-accent": "oklch(0.55 0.18 252)",
          "hola-accent-fg": "oklch(0.98 0 0)",
          "hola-danger": "oklch(0.55 0.2 25)",
          "hola-danger-fg": "oklch(0.98 0 0)"
        },
        "dark": {
          "hola-bg": "oklch(0.16 0.006 264)",
          "hola-surface": "oklch(0.205 0.008 264)",
          "hola-surface-elevated": "oklch(0.225 0.008 264)",
          "hola-fg": "oklch(0.98 0.002 264)",
          "hola-muted": "oklch(0.62 0.01 264)",
          "hola-brand": "oklch(0.98 0.002 264)",
          "hola-brand-fg": "oklch(0.18 0.005 264)",
          "hola-accent": "oklch(0.7 0.16 252)",
          "hola-accent-fg": "oklch(0.18 0.005 264)",
          "hola-danger": "oklch(0.65 0.2 25)",
          "hola-danger-fg": "oklch(0.98 0 0)"
        }
      }
    },
