{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "hola",
  "homepage": "https://oflabs44.github.io/hola-ui",
  "items": [
    {
      "$schema": "https://ui.shadcn.com/schema/registry-item.json",
      "name": "theme",
      "type": "registry:theme",
      "title": "Hola theme",
      "description": "Hola UI design tokens — neutrals shifted toward brand hue, translucent overlay borders, asymmetric light/dark.",
      "cssVars": {
        "theme": {
          "color-bg": "var(--hola-bg)",
          "color-surface": "var(--hola-surface)",
          "color-surface-elevated": "var(--hola-surface-elevated)",
          "color-fg": "var(--hola-fg)",
          "color-muted": "var(--hola-muted)",
          "color-brand": "var(--hola-brand)",
          "color-brand-fg": "var(--hola-brand-fg)",
          "color-accent": "var(--hola-accent)",
          "color-accent-fg": "var(--hola-accent-fg)",
          "color-danger": "var(--hola-danger)",
          "color-danger-fg": "var(--hola-danger-fg)",
          "font-sans": "var(--font-geist-sans), ui-sans-serif, system-ui, sans-serif",
          "font-mono": "var(--font-geist-mono), ui-monospace, 'SF Mono', Menlo, monospace"
        },
        "light": {
          "hola-bg": "oklch(1 0 0)",
          "hola-surface": "oklch(0.985 0.002 264)",
          "hola-surface-elevated": "oklch(1 0 0)",
          "hola-fg": "oklch(0.18 0.005 264)",
          "hola-muted": "oklch(0.55 0.01 264)",
          "hola-brand": "oklch(0.22 0.008 264)",
          "hola-brand-fg": "oklch(0.98 0.002 264)",
          "hola-accent": "oklch(0.55 0.18 252)",
          "hola-accent-fg": "oklch(0.98 0 0)",
          "hola-danger": "oklch(0.55 0.2 25)",
          "hola-danger-fg": "oklch(0.98 0 0)"
        },
        "dark": {
          "hola-bg": "oklch(0.16 0.006 264)",
          "hola-surface": "oklch(0.205 0.008 264)",
          "hola-surface-elevated": "oklch(0.225 0.008 264)",
          "hola-fg": "oklch(0.98 0.002 264)",
          "hola-muted": "oklch(0.62 0.01 264)",
          "hola-brand": "oklch(0.98 0.002 264)",
          "hola-brand-fg": "oklch(0.18 0.005 264)",
          "hola-accent": "oklch(0.7 0.16 252)",
          "hola-accent-fg": "oklch(0.18 0.005 264)",
          "hola-danger": "oklch(0.65 0.2 25)",
          "hola-danger-fg": "oklch(0.98 0 0)"
        }
      }
    },
    {
      "$schema": "https://ui.shadcn.com/schema/registry-item.json",
      "name": "utils",
      "type": "registry:lib",
      "title": "cn helper",
      "description": "Standard shadcn cn() — twMerge(clsx(inputs)).",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "registry/hola/lib/utils.ts",
          "type": "registry:lib",
          "target": "lib/utils.ts"
        }
      ]
    },
    {
      "$schema": "https://ui.shadcn.com/schema/registry-item.json",
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "Button on @base-ui/react, shadcn API (CVA + variant/size + data-slot), Catalyst-flavoured visual treatment.",
      "dependencies": ["@base-ui/react", "class-variance-authority"],
      "registryDependencies": ["theme", "utils"],
      "files": [
        {
          "path": "registry/hola/ui/button.tsx",
          "type": "registry:ui",
          "target": "components/ui/button.tsx"
        }
      ]
    },
    {
      "$schema": "https://ui.shadcn.com/schema/registry-item.json",
      "name": "badge",
      "type": "registry:ui",
      "title": "Badge",
      "description": "Status pill / label, tinted-bg variants. useRender hook for polymorphism (no Base UI primitive needed — badges aren't interactive).",
      "dependencies": ["@base-ui/react", "class-variance-authority"],
      "registryDependencies": ["theme", "utils"],
      "files": [
        {
          "path": "registry/hola/ui/badge.tsx",
          "type": "registry:ui",
          "target": "components/ui/badge.tsx"
        }
      ]
    },
    {
      "$schema": "https://ui.shadcn.com/schema/registry-item.json",
      "name": "input",
      "type": "registry:ui",
      "title": "Input",
      "description": "Text input on @base-ui/react/input. Asymmetric light/dark surfaces (raised vs etched), translucent overlay borders, responsive typography.",
      "dependencies": ["@base-ui/react"],
      "registryDependencies": ["theme", "utils"],
      "files": [
        {
          "path": "registry/hola/ui/input.tsx",
          "type": "registry:ui",
          "target": "components/ui/input.tsx"
        }
      ]
    },
    {
      "$schema": "https://ui.shadcn.com/schema/registry-item.json",
      "name": "input-group",
      "type": "registry:ui",
      "title": "Input Group",
      "description": "Composable wrapper for inputs with icons, text addons, buttons. Group root carries the border + focus ring; children are transparent.",
      "dependencies": ["@base-ui/react", "class-variance-authority"],
      "registryDependencies": ["theme", "utils", "input", "button"],
      "files": [
        {
          "path": "registry/hola/ui/input-group.tsx",
          "type": "registry:ui",
          "target": "components/ui/input-group.tsx"
        }
      ]
    }
  ]
}
